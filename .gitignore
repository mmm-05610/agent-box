# --- Python build / venv ---
__pycache__/
.pytest_cache/
*.pyc
*.pyo
*.pyd
*.egg-info/
build/
dist/
.venv/
venv/
env/

# --- IDE / editor ---
.idea/
.vscode/
.cursor/
*.swp
*.swo
*~

# --- OS / shell ---
.DS_Store
Thumbs.db
*.log

# --- Agent workspace (AI-generated artifacts, never commit) ---
workspace/

# --- Dev logs ---
logs/

# --- Local agent config dirs (per-host, never commit) ---
# These are agent runtimes that store identity/credentials on the host.
# They should never appear inside the agent-box source tree.
.claude/
.claude.json
.codex/
.agents/
.hermes/
.agent-box-local/

# --- Secrets / credentials (defense in depth) ---
*.auth
*credentials*
nul
