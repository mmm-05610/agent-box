#!/usr/bin/env python3
"""Thin launcher shim — `agent-box` is a console_script entry point
installed by pip in production, but for the MVP we also accept direct
invocation from a source checkout."""
import os
import sys

HERE = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, os.path.join(HERE, "src"))

from agent_box.cli import main
sys.exit(main())
